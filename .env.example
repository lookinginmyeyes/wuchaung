# Copy this file to .env and fill in your own Supabase project values.
# Never commit .env, because the service role key can read and write all experiment data.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_RUNS_TABLE=runs

# Optional but recommended: store recorded experiment videos in Supabase Storage too.
# Create this private bucket before enabling it.
SUPABASE_VIDEO_BUCKET=falling-ball-videos
SUPABASE_VIDEO_PREFIX=videos

# Optional: keep videos on a central server and let the local backend stream them on demand.
# Example with SSH tunnel: ssh -N -L 8878:127.0.0.1:8877 ubuntu@your-server
REMOTE_VIDEO_BASE_URL=http://127.0.0.1:8878
